# Self-hosted deployment example
# Replace all placeholder values before deployment.

OWLP_POSTGRES_DB=owlprotect
OWLP_POSTGRES_USER=owlprotect
OWLP_POSTGRES_PASSWORD=replace-with-secret
OWLP_POSTGRES_PORT=5432

OWLP_REDIS_PORT=6379

OWLP_CONTROL_PLANE_PORT=5180
OWLP_CONTROL_PLANE_URLS=http://+:5180
OWLP_CONTROL_PLANE_BASE_URL=http://control-plane-api:5180
OWLP_PERSISTENCE_PROVIDER=postgres
OWLP_PERSISTENCE_SEED_ON_STARTUP=false

OWLP_GATEWAY_ID=gw-prod-us-east-1
OWLP_GATEWAY_NAME=us-east-core-1
OWLP_GATEWAY_REGION=us-east

OWLP_ADMIN_PORTAL_PORT=4173
