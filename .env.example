# Root deployment inputs for docker compose.
# Copy to `.env` for local overrides.

OWLP_POSTGRES_DB=owlprotect
OWLP_POSTGRES_USER=owlprotect
OWLP_POSTGRES_PASSWORD=owlprotect
OWLP_POSTGRES_PORT=5432

OWLP_REDIS_PORT=6379

OWLP_CONTROL_PLANE_PORT=5180
OWLP_CONTROL_PLANE_URLS=http://+:5180
OWLP_CONTROL_PLANE_BASE_URL=http://control-plane-api:5180
OWLP_PERSISTENCE_PROVIDER=postgres
OWLP_PERSISTENCE_SEED_ON_STARTUP=true
OWLP_BOOTSTRAP_ADMIN_USERNAME=admin
OWLP_BOOTSTRAP_ADMIN_PASSWORD=change-bootstrap-admin-password
OWLP_BOOTSTRAP_ADMIN_PASSWORD_FILE=
OWLP_BOOTSTRAP_ADMIN_PASSWORD_HASH=
OWLP_ALLOW_GENERATED_BOOTSTRAP_ADMIN_PASSWORD=false
OWLP_SECRET_MOUNT_PATH=./.secrets

OWLP_GATEWAY_ID=gw-1
OWLP_GATEWAY_NAME=us-east-core-1
OWLP_GATEWAY_REGION=us-east

OWLP_ADMIN_PORTAL_PORT=4173
