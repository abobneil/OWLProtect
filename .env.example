# Root deployment inputs for docker compose.
# Copy to `.env` for local overrides.

OWLP_POSTGRES_DB=owlprotect
OWLP_POSTGRES_USER=owlprotect
OWLP_POSTGRES_PASSWORD=owlprotect
OWLP_POSTGRES_PORT=5432

OWLP_REDIS_PORT=6379

OWLP_CONTROL_PLANE_PORT=5180
OWLP_CONTROL_PLANE_URLS=http://+:5180
OWLP_CONTROL_PLANE_BASE_URL=http://control-plane-api:5180
OWLP_GATEWAY_PORT=5181
OWLP_GATEWAY_URLS=http://+:5181
OWLP_SCHEDULER_PORT=5182
OWLP_SCHEDULER_URLS=http://+:5182
OWLP_PERSISTENCE_PROVIDER=postgres
OWLP_PERSISTENCE_SEED_ON_STARTUP=true
OWLP_REDIS_CONNECTION_STRING=redis:6379
OWLP_BOOTSTRAP_ADMIN_USERNAME=admin
OWLP_BOOTSTRAP_ADMIN_PASSWORD=change-bootstrap-admin-password
OWLP_BOOTSTRAP_ADMIN_PASSWORD_FILE=
OWLP_BOOTSTRAP_ADMIN_PASSWORD_HASH=
OWLP_BOOTSTRAP_ADMIN_PASSWORD_HASH_FILE=
OWLP_ALLOW_GENERATED_BOOTSTRAP_ADMIN_PASSWORD=false
OWLP_SECRET_MOUNT_PATH=./.secrets
OWLP_AUDIT_RETENTION_ENABLED=true
OWLP_AUDIT_RETENTION_DAYS=365
OWLP_AUDIT_EXPORT_BATCH_SIZE=5000
OWLP_AUDIT_RETENTION_CHECK_INTERVAL_HOURS=24
OWLP_AUDIT_EXPORT_DIRECTORY=./audit-exports
OWLP_OBSERVABILITY_SERVICE_NAMESPACE=owlprotect
OWLP_OBSERVABILITY_OTLP_ENDPOINT=
OWLP_OBSERVABILITY_OTLP_PROTOCOL=grpc
OWLP_OBSERVABILITY_ENABLE_PROMETHEUS_ENDPOINT=true
OWLP_OBSERVABILITY_ENABLE_REQUEST_LOGGING=true
OWLP_OBSERVABILITY_REDACT_IP_ADDRESSES=true

OWLP_GATEWAY_ID=gw-1
OWLP_GATEWAY_NAME=us-east-core-1
OWLP_GATEWAY_REGION=us-east
OWLP_GATEWAY_TRUST_BUNDLE_FILE=/var/lib/owlprotect/gateway-trust-bundle.json
OWLP_GATEWAY_STATE_PATH=./.gateway-state

OWLP_ADMIN_PORTAL_PORT=4173
OWLP_ADMIN_PORTAL_CONTROL_PLANE_BASE_URL=
