<Application
    x:Class="OWLProtect.WindowsClientUi.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentColor">#FF2A7B66</Color>
            <Color x:Key="SurfaceColor">#FF0F1619</Color>
            <Color x:Key="SurfaceStrongColor">#FF172227</Color>
            <Color x:Key="TextColor">#FFF2F3EF</Color>
            <Color x:Key="MutedTextColor">#FFA6B3AE</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceStrongBrush" Color="{StaticResource SurfaceStrongColor}" />
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
            <FontFamily x:Key="AppFontFamily">Bahnschrift</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
