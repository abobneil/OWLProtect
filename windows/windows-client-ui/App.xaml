<Application
    x:Class="OWLProtect.WindowsClientUi.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentColor">#FF5F33A3</Color>
            <Color x:Key="SurfaceColor">#FF14111B</Color>
            <Color x:Key="SurfaceStrongColor">#FF261D34</Color>
            <Color x:Key="TextColor">#FFF4F2F8</Color>
            <Color x:Key="MutedTextColor">#FFAA9FBD</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceStrongBrush" Color="{StaticResource SurfaceStrongColor}" />
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
            <FontFamily x:Key="AppFontFamily">Roboto</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>

